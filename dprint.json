{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 120,
  "indentWidth": 2,
  "newLineKind": "lf",
  "markdown": {
    "textWrap": "maintain"
  },
  "includes": ["**/*.md"],
  "excludes": ["_build/**", "deps/**", ".claude/skills/**", "documentation/**", "AGENTS.md", "usage-rules/**", ".obsidian/**", "Review Docs.md"],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.21.1.wasm"
  ]
}
